# SoundFlow BI Agent — environment variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Slack (Phase 3 + 4) ────────────────────────────────────────────────────
# Bot token:  Slack app settings → OAuth → Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# Signing secret: Slack app settings → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=...
# App-level token (required for Socket Mode): Settings → Basic Information → App-Level Tokens (xapp-...)
SLACK_APP_TOKEN=xapp-...
# Slack user ID of the person who can approve new dashboards (e.g. U12345678)
# Leave empty to allow any user to approve
REVIEWER_SLACK_USER_ID=

# ── Lightdash (Phase 2 + 3) ────────────────────────────────────────────────
# Base URL of your self-hosted Lightdash instance
LIGHTDASH_BASE_URL=http://localhost:8090
# Personal access token: Lightdash → Settings → API tokens
LIGHTDASH_TOKEN=...
# Project UUID: visible in the Lightdash URL when browsing a project
LIGHTDASH_PROJECT_UUID=...

# ── DuckDB (Phase 4) ────────────────────────────────────────────────────────
# Path to the soundflow.duckdb file (relative to repo root or absolute)
DUCKDB_PATH=soundflow.duckdb
